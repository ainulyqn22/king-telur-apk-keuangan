# Public Supabase project URL and anonymous browser key.
# Security must be enforced by PostgreSQL row-level security; never put a
# service-role key or other server secret in a VITE_* variable.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"

# Optional development setting used by vite.config.ts.
DISABLE_HMR="false"

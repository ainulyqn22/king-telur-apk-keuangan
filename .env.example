# Browser-safe values used by Supabase SSR clients.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-public-publishable-or-anon-key"

# Server-only secret used for privileged auth admin flows such as invitations.
# Never expose this as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Absolute application URL used in auth emails and redirects.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
